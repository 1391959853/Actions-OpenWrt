# OpenWrt .config for WG3526 (GL-MT3526) with 32MB flash
# Target: ramips/mt7621, Kernel: 6.12
# Includes RG200U-CN module support, qmodem-next, sms-forwarder-next

CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_glinet_gl-mt3526=y

# Kernel version
CONFIG_LINUX_6_12=y

# Base configuration
CONFIG_DEVEL=y
CONFIG_KERNEL_DEBUG_INFO=n
CONFIG_KERNEL_DEBUG_LL=n
CONFIG_KERNEL_KASAN=n
CONFIG_KERNEL_UBSAN=n
CONFIG_KERNEL_CC_STACKPROTECTOR_NONE=y
CONFIG_KERNEL_STACKPROTECTOR=n

# Filesystem
CONFIG_TARGET_ROOTFS_INITRAMFS=n
CONFIG_TARGET_ROOTFS_EXT4FS=n
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# USB and serial drivers for RG200U-CN
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y

# PPP support
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_ppp-mod-pppol2tp=n

# Base system packages
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# qmodem-next (enable, disable qmodem)
CONFIG_PACKAGE_qmodem=y
CONFIG_PACKAGE_luci-app-qmodem-next=y
CONFIG_PACKAGE_luci-i18n-qmodem-next-zh-cn=y
# CONFIG_PACKAGE_luci-app-qmodem is not set

# sms-forwarder-next (enable, disable sms-forwarder)
CONFIG_PACKAGE_sms-forwarder-next=y
CONFIG_PACKAGE_luci-app-sms-forwarder-next=y
CONFIG_PACKAGE_luci-i18n-sms-forwarder-next-zh-cn=y
# CONFIG_PACKAGE_sms-forwarder is not set
# CONFIG_PACKAGE_luci-app-sms-forwarder is not set

# Optional tools for module
CONFIG_PACKAGE_quectel-CM=y
CONFIG_PACKAGE_ndisc6=n    # Disable if not needed
CONFIG_PACKAGE_rdisc6=n

# Remove unnecessary packages to save space
CONFIG_PACKAGE_kmod-ipv6=n
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iwinfo=y

# Disable unused features
CONFIG_KERNEL_DEBUG_FS=n
CONFIG_KERNEL_DEBUG_KERNEL=n
CONFIG_KERNEL_DYNAMIC_DEBUG=n

# Kernel module dependencies (automatic)
CONFIG_USB_SERIAL_OPTION=y
CONFIG_USB_NET_QMI_WWAN=y
CONFIG_USB_NET_CDC_NCM=y

# Final size optimization
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS_BLOCK_SIZE=256
